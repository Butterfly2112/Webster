generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TokenType {
  refreshJwtToken
  emailChange
  passwordChange
}

enum AssetType {
  image
  background
}

model User {
  id                Int      @id @default(autoincrement())
  login             String   @unique
  username          String
  email             String   @unique
  password_hash     String?
  google_id         String?  @unique
  avatar_url        String   @default("default")
  avatar_public_id  String?
  is_email_verified Boolean  @default(false)
  created_at        DateTime @default(now())

  tokens   Token[]
  projects Project[]
  assets   Asset[]
  fonts    Font[]

  @@index([email])
  @@index([login])
}

model Token {
  id         Int       @id @default(autoincrement())
  type       TokenType
  token      String    @unique
  expires_at DateTime?
  new_email  String?
  created_at DateTime  @default(now())

  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  @@index([user_id, type])
}

model Project {
  id                  Int      @id @default(autoincrement())
  title               String
  description         String?
  canvas_data         Json     @default("{}")
  width               Int      @default(800)
  height              Int      @default(600)
  thumbnail_url       String?
  thumbnail_public_id String?
  is_template         Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  owner    User? @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  owner_id Int?

  assets  Asset[]
  history ProjectHistory[]

  @@index([owner_id])
  @@index([is_template])
}

model ProjectHistory {
  id                  Int      @id @default(autoincrement())
  canvas_data         Json
  version             Int
  created_at          DateTime @default(now())
  thumbnail_url       String?
  thumbnail_public_id String?

  project    Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id Int

  @@index([project_id])
}

model Asset {
  id            Int       @id @default(autoincrement())
  type          AssetType
  url           String
  public_id     String
  original_name String
  file_size     Int
  created_at    DateTime  @default(now())

  owner    User? @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  owner_id Int?

  project    Project? @relation(fields: [project_id], references: [id], onDelete: Cascade)
  project_id Int?

  @@index([owner_id])
}

model Font {
  id         Int      @id @default(autoincrement())
  name       String
  url        String
  public_id  String
  format     String
  is_default Boolean  @default(false)
  created_at DateTime @default(now())

  owner    User? @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  owner_id Int?

  @@index([owner_id])
}
